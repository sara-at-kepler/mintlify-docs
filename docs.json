{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kepler",
  "colors": {
    "primary": "#1A5A40",
    "light": "#4A9D76",
    "dark": "#14412F"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "glossary"
        ]
      },
      {
        "group": "MCP connector",
        "pages": [
          "mcp/overview",
          "mcp/connect",
          "mcp/tools",
          "mcp/prompts",
          "mcp/examples"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Kepler app",
          "href": "https://app.kepler.ai",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Website",
          "href": "https://kepler.ai",
          "icon": "/images/icons/kepler-mark.svg"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@kepler.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Kepler",
      "href": "https://app.kepler.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://kepler.ai",
      "x": "https://x.com/kepler_ai"
    }
  }
}
