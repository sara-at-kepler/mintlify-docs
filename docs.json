{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Kepler",
  "colors": {
    "primary": "#3d6b38",
    "light": "#6ab060",
    "dark": "#0B1F17"
  },
  "seo": {
    "metatags": {
      "og:site_name": "Kepler",
      "og:type": "website",
      "twitter:card": "summary_large_image"
    },
    "indexing": "all"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Geist"
  },
  "navigation": {
    "groups": [
      {
        "group": "Documentation",
        "pages": [
          "index",
          "quickstart",
          "faq",
          "sso",
          "glossary",
          "contact"
        ]
      },
      {
        "group": "MCP connector",
        "pages": [
          "mcp/overview",
          "mcp/app-vs-connector",
          "mcp/connect",
          "mcp/examples",
          "mcp/best-practices",
          "mcp/data-handling",
          {
            "group": "Reference",
            "expanded": false,
            "pages": [
              "mcp/tools",
              "mcp/prompts"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@kepler.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Kepler",
      "href": "https://app.kepler.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://kepler.ai",
      "x": "https://x.com/kepler_ai"
    }
  }
}
